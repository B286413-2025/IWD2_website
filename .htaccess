# Rules adapted from Dani Krossing tutorial, https://www.youtube.com/watch?v=zJxCq6D14eM
# With ELM's (GPT 5.2) help, https://elm.edina.ac.uk/elm-new
RewriteEngine On

# Dynamic routes first
RewriteRule ^loading/([0-9]+)/?$ loading_page.php?job_id=$1 [L,QSA]
RewriteRule ^results/([0-9]+)/?$ results.php?job_id=$1 [L,QSA]

# Simple extensionless pages second
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^([A-Za-z0-9_-]+)/?$ $1.php [L,QSA]

# From Dani Krossing tutorial, https://www.youtube.com/watch?v=kPtS4vO42II
ErrorDocument 404 /~s2883992/website/not_found.php 
